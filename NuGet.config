<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Internal BaGet NuGet feed — all TransportPlatform packages published here.
      Add this NuGet.config to every service repo so dotnet restore finds packages.

      BaGet runs as a Docker container:
        docker run -p 5555:80 loicsharma/baget
      
      Manage packages at: http://nuget.internal (or http://localhost:5555 in dev)
    -->
    <add key="TransportPlatform" value="http://localhost:5555/v3/index.json"  allowInsecureConnections="true" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
